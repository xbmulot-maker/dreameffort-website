---
import Layout from '../layouts/Layout.astro'

const demoUrl = 'https://demo.dreameffort.com/demo'
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 border-b border-border bg-bg/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight">
        <span class="text-blue-400">Dream</span>Effort
      </a>
      <a
        href={demoUrl}
        class="px-5 py-2 text-sm font-medium rounded-lg bg-accent hover:bg-accent-light text-white transition-colors"
      >
        Try the Demo
      </a>
    </div>
  </nav>

  <main>
    <!-- Section 1: Hero -->
    <section class="pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight leading-[1.1] mb-8">
          Tasks lie.<br />
          <span class="text-accent-light">Effort does not.</span>
        </h1>
        <p class="text-xl md:text-2xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
          Your strategy declares what matters.<br />
          Are your top priorities actually getting funded?
        </p>
        <p class="text-lg text-text-muted max-w-2xl mx-auto mb-12">
          DreamEffort scores misalignment by priority weight: a 5% gap on your #1 initiative shows differently than the same gap on your #5. Real activity. No timesheets. No estimates.
        </p>
        <a
          href={demoUrl}
          class="inline-flex items-center gap-2 px-8 py-4 text-lg font-semibold rounded-xl bg-accent hover:bg-accent-light text-white transition-colors shadow-lg shadow-accent/20"
        >
          Try the Demo
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </section>

    <!-- Section 2: Problem -->
    <section class="py-24 px-6 border-t border-border">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">
          Three questions you can't answer fast.
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="p-6 rounded-xl bg-bg-card border border-border">
            <div class="text-3xl mb-4 text-amber">?</div>
            <p class="text-text-muted leading-relaxed">
              When 4 initiatives slip at once, which one hurts most? You don't know — slips aren't all equal weight.
            </p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-border">
            <div class="text-3xl mb-4 text-amber">?</div>
            <p class="text-text-muted leading-relaxed">
              Where is your team actually spending time vs. what you declared as priority? Status reports won't tell you.
            </p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-border">
            <div class="text-3xl mb-4 text-amber">?</div>
            <p class="text-text-muted leading-relaxed">
              Are your underfunded #1 priorities staying that way? You'll find out at the quarterly review — too late.
            </p>
          </div>
        </div>
        <p class="text-center text-text-dim mt-10 italic">
          The only way to answer these today: Excel, manual rollups, and hope the data is still fresh.
        </p>
      </div>
    </section>

    <!-- Section 3: Solution -->
    <section class="py-24 px-6 border-t border-border">
      <div class="max-w-5xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-12">
          DreamEffort shows you where effort <span class="text-accent-light">actually</span> goes — and which gap hurts most.
        </h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="p-6 rounded-xl bg-bg-card border border-border hover:border-accent/40 transition-colors">
            <div class="w-12 h-12 rounded-lg bg-accent-glow flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold mb-3">Effort, distributed</h3>
            <p class="text-sm text-text-muted">See how engineering investment distributes across your priorities — fresh every morning, not last quarter.</p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-accent/40 hover:border-accent transition-colors">
            <div class="w-12 h-12 rounded-lg bg-accent-glow flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
              </svg>
            </div>
            <h3 class="text-base font-semibold mb-3">Priority-weighted gaps</h3>
            <p class="text-sm text-text-muted">See which misalignment hurts most — slips weighted by your priority order, not by absolute size.</p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-border hover:border-accent/40 transition-colors">
            <div class="w-12 h-12 rounded-lg bg-accent-glow flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold mb-3">Spot underfunding</h3>
            <p class="text-sm text-text-muted">Spot underfunded initiatives before the quarter is over.</p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-border hover:border-accent/40 transition-colors">
            <div class="w-12 h-12 rounded-lg bg-accent-glow flex items-center justify-center mx-auto mb-5">
              <svg class="w-6 h-6 text-accent-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-base font-semibold mb-3">Staffing recommendations</h3>
            <p class="text-sm text-text-muted">Who's available, what they specialize in, why they fit.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: How It Works -->
    <section class="py-24 px-6 border-t border-border bg-bg-card/50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
          Nothing changes for your team.
        </h2>
        <p class="text-text-muted text-center mb-16 text-lg">Three steps. Zero disruption.</p>
        <div class="grid md:grid-cols-3 gap-12">
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-bold text-accent-light">1</span>
            </div>
            <h3 class="text-xl font-semibold mb-3">Connect</h3>
            <p class="text-text-muted">Link your planning and activity tools. Read-only access.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-bold text-accent-light">2</span>
            </div>
            <h3 class="text-xl font-semibold mb-3">Collect</h3>
            <p class="text-text-muted">Every commit traced back to your strategic priorities. Automatically.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
              <span class="text-2xl font-bold text-accent-light">3</span>
            </div>
            <h3 class="text-xl font-semibold mb-3">See</h3>
            <p class="text-text-muted">Effort distribution, alignment gaps, and staffing recommendations — updated daily.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4.5: Real Activity (NEW) -->
    <section class="py-24 px-6 border-t border-border">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
          No timesheets. Just <span class="text-accent-light">observed reality</span>.
        </h2>
        <p class="text-text-muted text-center mb-16 text-lg">
          DreamEffort reads what already happens in your tools.
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="p-6 rounded-xl bg-bg-card border border-border">
            <h3 class="text-lg font-semibold mb-3 text-accent-light">Commits</h3>
            <p class="text-text-muted leading-relaxed">
              Automatically linked to the work they served — using the references your team already puts in commit messages.
            </p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-border">
            <h3 class="text-lg font-semibold mb-3 text-accent-light">Scope changes</h3>
            <p class="text-text-muted leading-relaxed">
              Tracked over time — every change to what's in scope, not just today's snapshot.
            </p>
          </div>
          <div class="p-6 rounded-xl bg-bg-card border border-border">
            <h3 class="text-lg font-semibold mb-3 text-accent-light">Specialties</h3>
            <p class="text-text-muted leading-relaxed">
              Inferred from where people actually wrote code — not declared skills, not a static profile.
            </p>
          </div>
        </div>
        <p class="text-center text-text-dim mt-10 max-w-2xl mx-auto">
          Your engineers do nothing different. We refresh nightly — fresh signals every morning, not yet another dashboard begging for attention.
        </p>
      </div>
    </section>

    <!-- Section 5: Screenshots — Strategy -->
    <section class="py-24 px-6 border-t border-border">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center">
          Declared vs. Actual — at a glance.
        </h2>
        <p class="text-text-muted text-center mb-16 text-lg">
          The Strategy page shows whether your investment matches your intent.
        </p>
        <div>
          <div class="rounded-xl border border-border overflow-hidden bg-bg-card">
            <img
              src="/screenshots/strategy-effort.png"
              alt="Strategy page — Effort distribution showing declared vs actual investment per initiative, with mixed alignment colors and target markers"
              class="w-full"
              loading="lazy"
            />
          </div>
          <p class="text-sm text-text-dim mt-3 text-center">Effort distribution — declared vs. actual investment, color-coded by alignment</p>
        </div>
      </div>
    </section>

    <!-- Section 6: Signals -->
    <section class="py-24 px-6 border-t border-border bg-bg-card/50">
      <div class="max-w-7xl mx-auto">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Problems surface themselves.
          </h2>
          <p class="text-xl text-text-muted leading-relaxed">
            Stale work. Capacity gaps. Delivery risk. Detected automatically from real activity — and ranked by your priority order, not by "highest severity wins."
          </p>
        </div>
        <div>
          <div class="rounded-xl border border-border overflow-hidden bg-bg-card">
            {/* TODO: replace src with /screenshots/signals-collapsed.png once captured (collapsed initiative sections with severity pills) */}
            <img
              src="/screenshots/signals-delivery.png"
              alt="Signals page collapsed view — initiative sections with severity pills as colored circles, priority badges, and hero KPI counts"
              class="w-full"
              loading="lazy"
            />
          </div>
          <p class="text-sm text-text-dim mt-3 text-center">Signals page — collapsed view, severity pills + priority badges</p>
        </div>
      </div>
    </section>

    <!-- Section 7: Final CTA -->
    <section class="py-32 px-6 border-t border-border">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          See where your effort <span class="text-accent-light">really</span> goes.
        </h2>
        <p class="text-xl text-text-muted mb-10">
          Explore the live demo with sample data. No signup required.
        </p>
        <a
          href={demoUrl}
          class="inline-flex items-center gap-2 px-8 py-4 text-lg font-semibold rounded-xl bg-accent hover:bg-accent-light text-white transition-colors shadow-lg shadow-accent/20"
        >
          Try the Demo
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-border py-10 px-6">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="text-text-dim text-sm">
        &copy; {new Date().getFullYear()} DreamEffort. All rights reserved.
      </div>
      <div class="flex items-center gap-6 text-sm text-text-dim">
        <a href="/contact" class="hover:text-text transition-colors">Contact</a>
        <a href="/privacy" class="hover:text-text transition-colors">Privacy</a>
      </div>
    </div>
  </footer>
</Layout>
